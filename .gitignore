*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ────────────────────────────────────────────────────────────
# 编辑器 / IDE 配置（开发软件配置目录，按豆哥规则不上传）
# ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ────────────────────────────────────────────────────────────
# 操作系统生成文件
# ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ────────────────────────────────────────────────────────────
# 环境变量 / 密钥（私密信息绝不入库）
# ────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/

# ────────────────────────────────────────────────────────────
# 缓存 / 临时
# ────────────────────────────────────────────────────────────
.cache/
.temp/
.tmp/
*.tsbuildinfo
.eslintcache
.stylelintcache
.parcel-cache/
.vite/

# ────────────────────────────────────────────────────────────
# 测试 / 覆盖率
